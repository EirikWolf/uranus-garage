generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  accounts      Account[]
  sessions      Session[]
  forks         RecipeFork[]
  ratings       Rating[]
  listings      Listing[]
  brewSwaps     BrewSwap[]
  swapSignups   SwapParticipant[]
  simulations   Simulation[]
  articleComments ArticleComment[]
  brewPosts       BrewPost[]
  createdAt     DateTime          @default(now())
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // selger, kjoper, bytter
  price       String?
  location    String
  imageUrl    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, type, createdAt])
  @@index([userId])
}

model BrewSwap {
  id              String            @id @default(cuid())
  title           String
  description     String
  baseRecipe      String?
  totalLiters     Float
  portionSize     Float
  maxParticipants Int
  brewDate        DateTime
  location        String
  status          String            @default("planlagt")
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  participants    SwapParticipant[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model SwapParticipant {
  id        String   @id @default(cuid())
  swapId    String
  swap      BrewSwap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  plan      String?
  result    String?
  forkId    String?
  createdAt DateTime @default(now())

  @@unique([swapId, userId])
}

model RecipeFork {
  id             String       @id @default(cuid())
  name           String
  description    String?
  // Parent tracking — either a Sanity recipe or another fork
  parentSanityId String?      // Sanity _id if forked from CMS recipe
  parentForkId   String?      // If forked from another fork
  parentFork     RecipeFork?  @relation("ForkTree", fields: [parentForkId], references: [id])
  children       RecipeFork[] @relation("ForkTree")
  // Recipe data (snapshot at time of fork)
  style          String?
  difficulty     String?
  batchSize      Float        @default(20)
  grains         Json         @default("[]")
  hops           Json         @default("[]")
  yeast          Json         @default("{}")
  additions      Json         @default("[]")
  process        Json         @default("[]")
  // What changed
  changeNotes    String?
  // Brew results
  brewDate       DateTime?
  og             Float?
  fg             Float?
  tastingNotes   String?
  // Meta
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  ratings        Rating[]
  simulations    Simulation[]
  isPublic       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([parentForkId])
  @@index([parentSanityId])
}

model Rating {
  id        String     @id @default(cuid())
  value     Int        // 1-5
  comment   String?
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  forkId    String
  fork      RecipeFork @relation(fields: [forkId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([userId, forkId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BrewSession {
  id          String          @id @default(cuid())
  name        String          @unique
  deviceName  String?
  deviceId    String?
  createdOn   DateTime
  endingOn    DateTime?
  og          Float?
  fg          Float?
  abv         Float?
  numDays     Int?
  isActive    Boolean         @default(false)
  brewLogSlug String?
  readings    SensorReading[]
  importedAt  DateTime        @default(now())

  @@index([isActive])
}

model SensorReading {
  id          String       @id @default(cuid())
  sessionId   String
  session     BrewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  timestamp   DateTime
  temperature Float?
  gravity     Float?
  pressure    Float?
  battery     Float?
  rssi        Int?
  createdAt   DateTime     @default(now())

  @@unique([sessionId, timestamp])
  @@index([sessionId, timestamp])
}

model BrewPost {
  id           String    @id @default(cuid())
  title        String
  body         String
  images       String[]
  brewDate     DateTime?
  tags         String[]
  source       String    @default("web") // "web" | "synthiq"

  // Innlogget bruker (web)
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Syntetisk / API-bruker
  authorName   String?
  authorAvatar String?

  likes        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([createdAt])
  @@index([userId])
  @@index([source])
}

model ArticleComment {
  id              String   @id @default(cuid())
  sanityArticleId String
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body            String
  createdAt       DateTime @default(now())

  @@index([sanityArticleId, createdAt])
}

model Simulation {
  id              String      @id @default(cuid())
  name            String
  forkId          String?
  fork            RecipeFork? @relation(fields: [forkId], references: [id], onDelete: SetNull)
  brewLogSanityId String?
  params          Json
  result          Json
  isPublic        Boolean     @default(false)
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([forkId])
}
